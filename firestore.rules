rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }
    function isQA() {
      return isSignedIn() && getRole() in ['admin', 'manager', 'qa'];
    }
    function isEditor() {
      return isSignedIn() && getRole() in ['admin', 'manager', 'qa'];
    }
    function myEmail() {
      return request.auth.token.email.lower();
    }
    function inviteExists() {
      return exists(/databases/$(database)/documents/invites/$(myEmail()));
    }
    function inviteRole() {
      return get(/databases/$(database)/documents/invites/$(myEmail())).data.role;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid
        && inviteExists()
        && request.resource.data.role == inviteRole();
      allow update: if isAdmin() || request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    match /invites/{email} {
      // Signed-in user can read their own invite (needed for sign-in flow).
      allow get: if isSignedIn() && (email == myEmail() || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /complaints/{id} {
      // Public get by exact doc ID = refNo (used by /track). Listing still requires sign-in.
      allow get: if true;
      allow list: if isSignedIn();
      // Internal users: full create. Public: only if source=public, status=open, submitterEmail present.
      allow create: if isEditor() || (
        request.resource.data.source == 'public'
        && request.resource.data.status == 'open'
        && request.resource.data.submitterEmail is string
        && request.resource.data.submitterEmail.matches('^[^@]+@[^@]+\\.[^@]+$')
        && request.resource.data.description.size() < 5000
      );
      allow update: if isEditor();
      allow delete: if isAdmin();
    }

    match /inspections/{id} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isEditor() || (
        request.resource.data.source == 'public'
        && request.resource.data.status == 'pending'
        && request.resource.data.submitterEmail is string
        && request.resource.data.submitterEmail.matches('^[^@]+@[^@]+\\.[^@]+$')
      );
      allow update: if isEditor();
      allow delete: if isAdmin();
    }

    match /publicSubmissions/{id} {
      // Unauthenticated users can create new submissions, but only with valid required fields.
      allow create: if request.resource.data.keys().hasAll([
          'type', 'referenceNo', 'submitterName', 'submitterEmail',
          'submitterCompany', 'description', 'status', 'createdAt'
        ])
        && request.resource.data.type in ['complaint', 'inspection']
        && request.resource.data.status == 'new'
        && request.resource.data.submitterName is string
        && request.resource.data.submitterName.size() > 0
        && request.resource.data.submitterName.size() < 200
        && request.resource.data.submitterEmail.matches('^[^@]+@[^@]+\\.[^@]+$')
        && request.resource.data.description.size() < 5000;
      // Only QA/admin can read or update.
      // Public can look up a submission by exact reference number (= doc ID).
      allow get: if true;
      // Public can also query by PI No., capped to 10 results per query (used by /track).
      // Wider listing still requires QA role.
      allow list: if isQA() || (request.query.limit is int && request.query.limit <= 10);
      allow update: if isQA();
      allow delete: if isAdmin();
    }

    match /auditLogs/{id} {
      allow read: if isQA();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /letterheads/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /suppliers/{id} {
      // Public read allowed: supplier names are needed by the unauthenticated complaint form
      // so submitters can pick the factory from a dropdown.
      allow read: if true;
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }
  }
}
